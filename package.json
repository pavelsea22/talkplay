{
  "name": "talkplay",
  "version": "1.0.0",
  "scripts": {
    "lint": "eslint src tests",
    "dev:api": "tsc --skipLibCheck && PORT=3001 node dist/server.js",
    "dev:ui": "vite",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "build": "npm run lint && tsc && vite build",
    "build:worker": "vite build",
    "typecheck:worker": "tsc --project tsconfig.worker.json",
    "deploy": "npm run build:worker && wrangler deploy",
    "start": "node dist/server.js",
    "test": "jest",
    "verify": "npm run lint && npm test"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "microsoft-cognitiveservices-speech-sdk": "^1.48.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "svelte": "^5.54.1",
    "ts-jest": "^29.1.4",
    "typescript": "^5.3.3",
    "vite": "^6.4.1",
    "wrangler": "^4.85.0"
  }
}
