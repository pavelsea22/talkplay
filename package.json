{
  "name": "talkplay",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc && esbuild src/client.ts --bundle --outfile=src/public/client.js",
    "start": "node dist/server.js",
    "dev": "tsc --skipLibCheck && esbuild src/client.ts --bundle --outfile=src/public/client.js && node dist/server.js",
    "test": "jest"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "microsoft-cognitiveservices-speech-sdk": "^1.48.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.3.3"
  }
}
