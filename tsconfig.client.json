{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["src/client/**/*", "src/words.ts", "src/evaluate.ts", "src/arrayUtils.ts", "index.html", "activity/index.html", "vite.config.ts"]
}
